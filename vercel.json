{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "HUSKY=0 npm install",
    "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
    "headers": [
        {
            "source": "/sw.js",
            "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        }
    ]
}
